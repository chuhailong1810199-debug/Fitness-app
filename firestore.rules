rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── LEADS collection ─────────────────────────────────
    // Public: anyone can create a lead (contact form from landing page)
    //   - name and email must be non-empty strings
    //   - only allowed fields to prevent data stuffing
    // Coach only: read, update (status changes), delete
    match /leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'goal', 'frequency',
          'service', 'note', 'createdAt', 'source', 'status'
        ]);

      allow read, update, delete: if
        request.auth != null &&
        request.auth.token.email == 'chuhailong1810199@gmail.com';
    }

    // ── All other collections: keep existing auth rules ──
    // clients, sessions, checkpoints, etc. require auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
